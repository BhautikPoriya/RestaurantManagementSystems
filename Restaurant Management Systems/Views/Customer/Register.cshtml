@model RegisterModel

@{
    var loginUrl = Url.Action("Login", "Customer");
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-side new-user">
            <h2 class="auth-title1">Create Account</h2>
            <p>Please provide the details below to register.</p>
            <button type="button" class="btn btn-register" onclick="location.href='@loginUrl'">
                Back to Login
            </button>
        </div>

        <div class="auth-side returning-user">
            <h2 class="auth-title">Register</h2>

            <form asp-action="Register" method="post" autocomplete="off" class="auth-form">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                @if (Model.UsernamesEnabled)
                {
                    <div class="form-group">
                        <label asp-for="Username"></label>
                        <input asp-for="Username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <label asp-for="Email"></label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                }

                <div class="form-group">
                    <label asp-for="Firstname"></label>
                    <input asp-for="Firstname" class="form-control" />
                    <span asp-validation-for="Firstname" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Lastname"></label>
                    <input asp-for="Lastname" class="form-control" />
                    <span asp-validation-for="Lastname" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-login w-100">
                    Register
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script asp-location="Footer">
        $(function () {
            // client-side scripts (if needed)
        });
    </script>
}